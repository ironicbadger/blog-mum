---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { displayDate } from '../../components/dates';
import { imagePath, imageSrcset, withAssetBase } from '../../components/image';
import { siteData as data } from '../../data/posts';

export function getStaticPaths() {
  return data.posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { site, posts, authors } = data;
const author = authors.find((item) => item.id === post.author_id);
const readMore = posts.filter((item) => item.slug !== post.slug).slice(0, 3);
const authorById = Object.fromEntries(authors.map((item) => [item.id, item]));
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  bodyClass="post-template"
  canonicalPath={`/${post.slug}/`}
  ogType="article"
  ogImage={post.feature_image}
>
  <main id="site-main" class="site-main">
    <article class="article post ">
      <header class="article-header gh-canvas">
        <h1 class="article-title">{post.title}</h1>

        <div class="article-byline">
          <section class="article-byline-content">
            <ul class="author-list">
              <li class="author-list-item">
                <a href={`/author/${author.slug}/`} class="author-avatar">
                  <img class="author-profile-image" src={imagePath(author.profile_image, 100)} alt={author.name} />
                </a>
              </li>
            </ul>
            <div class="article-byline-meta">
              <h4 class="author-name"><a href={`/author/${author.slug}/`}>{author.name}</a></h4>
              <div class="byline-meta-content">
                <time class="byline-meta-date" datetime={post.published_date}>{displayDate(post.published_date)}</time>
                <span class="byline-reading-time"><span class="bull">&bull;</span> {post.reading_minutes} min read</span>
              </div>
            </div>
          </section>
        </div>

        {post.feature_image && (
          <figure class="article-image">
            <img
              srcset={imageSrcset(post.feature_image)}
              sizes="(min-width: 1400px) 1400px, 92vw"
              src={imagePath(post.feature_image, 2000)}
              alt={post.title}
            />
          </figure>
        )}
      </header>

      <section class="gh-content gh-canvas" set:html={withAssetBase(post.html)}></section>
    </article>
  </main>

  <section class="footer-cta ">
    <div class="inner">
      <h2>Sign up for more like this.</h2>
      <a class="footer-cta-button" href="#/portal" data-portal>
        <div class="footer-cta-input">Enter your email</div>
        <span>Subscribe</span>
      </a>
    </div>
  </section>

  <aside class="read-more-wrap">
    <div class="read-more inner">
      {readMore.map((item) => (
        <PostCard post={item} author={authorById[item.author_id]} />
      ))}
    </div>
  </aside>
</BaseLayout>
