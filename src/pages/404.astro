---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import data from '../data/site.json';

const { site, posts, authors } = data;
const authorById = Object.fromEntries(authors.map((author) => [author.id, author]));
---

<BaseLayout title={`Page not found - ${site.title}`} description={site.description} bodyClass="error-template" canonicalPath="/404/">
  <main id="site-main" class="site-main outer error-content">
    <div class="inner">
      <section class="error-message">
        <h1 class="error-code">404</h1>
        <p class="error-description">Page not found</p>
        <a class="error-link" href="/">Go to the front page</a>
      </section>
      <div class="post-feed">
        {posts.slice(0, 3).map((post) => (
          <PostCard post={post} author={authorById[post.author_id]} />
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
