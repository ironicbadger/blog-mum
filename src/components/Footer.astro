---
const { site } = Astro.props;
---

<footer class="site-footer outer">
  <div class="inner">
    <section class="copyright"><a href="/">{site.title}</a> &copy; 2026</section>
    <nav class="site-footer-nav"></nav>
    <div class="site-footer-powered">
      <a class="site-footer-github" href="https://github.com/ironicbadger/blog-mum" target="_blank" rel="noopener" aria-label="View source on GitHub" title="GitHub">
        <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
          <path d="M8 0C3.58 0 0 3.67 0 8.2c0 3.62 2.29 6.69 5.47 7.78.4.08.55-.18.55-.4 0-.2-.01-.86-.01-1.57-2.01.38-2.53-.5-2.69-.96-.09-.24-.48-.96-.82-1.15-.28-.16-.68-.55-.01-.56.63-.01 1.08.59 1.23.84.72 1.24 1.87.89 2.33.68.07-.53.28-.89.51-1.1-1.78-.21-3.64-.91-3.64-4.04 0-.89.31-1.62.82-2.19-.08-.21-.36-1.04.08-2.16 0 0 .67-.22 2.2.84A7.43 7.43 0 0 1 8 3.92c.68 0 1.36.09 2 .28 1.53-1.06 2.2-.84 2.2-.84.44 1.12.16 1.95.08 2.16.51.57.82 1.3.82 2.19 0 3.14-1.87 3.83-3.65 4.04.29.26.54.76.54 1.54 0 1.1-.01 1.99-.01 2.27 0 .22.15.48.55.4A8.08 8.08 0 0 0 16 8.2C16 3.67 12.42 0 8 0Z" />
        </svg>
      </a>
      <span>powered by Astro</span>
    </div>
  </div>
</footer>

<style>
  .site-footer-powered {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 8px;
  }

  .site-footer-github {
    display: inline-flex;
    align-items: center;
    color: inherit;
  }

  .site-footer-github svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
</style>
