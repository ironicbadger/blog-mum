---
const { site, isHome = false } = Astro.props;
const nav = site.navigation || [];
---

<header id="gh-head" class="gh-head has-cover">
  <nav class="gh-head-inner inner gh-container">
    <div class="gh-head-brand">
      <a class="gh-head-logo" href="/">
        {site.logo ? <img src={site.logo} alt={site.title} /> : site.title}
      </a>
      <a class="gh-burger" role="button" aria-label="Open menu" tabindex="0">
        <div class="gh-burger-box">
          <div class="gh-burger-inner"></div>
        </div>
      </a>
    </div>
    <div class="gh-head-menu">
      <ul class="nav">
        {nav.map((item) => (
          <li class={`nav-${item.label.toLowerCase().replace(/[^a-z0-9]+/g, '-')} ${isHome && item.url === '/' ? 'nav-current' : ''}`}>
            <a href={item.url}>{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
    <div class="gh-head-actions">
      <a class="gh-head-button" href="#/portal/signup" data-portal="signup">Subscribe</a>
    </div>
  </nav>
</header>
